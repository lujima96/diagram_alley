        { "surface": "desktop", "id": "login",      "file": "desktop/login.html",      "status": "active" },
        { "surface": "mobile",  "id": "login-m",    "file": null,                      "status": "planned", "note": "V2 scope" }
      ]
    },
    {
      "route": "/register",
