    { "id": "ai-prompt-panel",  "file": "components/ai-prompt-panel.html", "states": 4  },
    { "id": "ascii-panel",      "file": "components/ascii-panel.html",     "states": 4  },
    { "id": "version-drawer",   "file": "components/version-drawer.html",  "states": 4  },
    { "id": "export-modal",     "file": "components/export-modal.html",    "states": 3  }
